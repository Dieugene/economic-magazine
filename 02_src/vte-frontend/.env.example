# Режим работы с API
# mock  — встроенные тестовые данные, бэкенд не нужен (по умолчанию)
# real  — реальный бэкенд по адресу NEXT_PUBLIC_API_URL
NEXT_PUBLIC_API_MODE=mock

# URL бэкенда (используется только при API_MODE=real)
# Локальная разработка: http://localhost:8000
# Docker Compose:      http://backend:8000 (имя сервиса в docker network)
NEXT_PUBLIC_API_URL=http://localhost:8000
